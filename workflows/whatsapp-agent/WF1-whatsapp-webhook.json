            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"conversation_id\": \"{{ $json[0].id }}\",\n  \"wa_message_id\": \"{{ $node['Extract Message'].json.wa_message_id }}\",\n  \"direction\": \"inbound\",\n  \"sender_type\": \"customer\",\n  \"message_type\": \"text\",\n  \"content\": \"{{ $node['Extract Message'].json.message_text }}\"\n}",
        "options": {}
      },
