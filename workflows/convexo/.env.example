# ============================================================
# Ekinoxis n8n Workflows — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ---------------------------
# Anthropic (Claude API)
# Used by all 3 workflows via the n8n Anthropic credential
# Create at: https://console.anthropic.com/
# ---------------------------
ANTHROPIC_API_KEY=sk-ant-...

# Model assignments (configured inside workflow JSONs):
# - Workflow 01: claude-opus-4-6   (complex financial analysis)
# - Workflow 02: claude-sonnet-4-6 (credit recovery diagnosis)
# - Workflow 03: claude-sonnet-4-6 (traffic fines legal analysis)

# ---------------------------
# Google Sheets
# The ID from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID/edit
# Set this in n8n: Settings → Environment Variables
# ---------------------------
GOOGLE_SHEET_ID=your_google_sheet_id_here

# ---------------------------
# Email — Sender addresses
# Both domains must be verified in your Resend dashboard
# SMTP credential is configured in n8n UI (not here):
#   Host: smtp.resend.com | Port: 465 | User: resend | Pass: <Resend API key>
# ---------------------------
FROM_EMAIL_CONVEXO=financial@convexo.org     # WF01 — Enterprise Credit
FROM_EMAIL_THRONIUM=servicios@thronium.org   # WF02 + WF03 — Legal Services
INTERNAL_EMAIL=ekinoxislabs@gmail.com        # Internal team notifications

# ---------------------------
# n8n Instance (self-hosted)
# ---------------------------
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
WEBHOOK_URL=http://localhost:5678

# ---------------------------
# Google OAuth2 (configured in n8n Credentials UI, not here)
# See QUICKSTART.md Step 3 for setup instructions
# ---------------------------
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
