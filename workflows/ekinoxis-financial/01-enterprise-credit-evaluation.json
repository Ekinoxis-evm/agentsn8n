    {
      "parameters": {
        "jsCode": "const extracts = $input.all();\nconst consolidatedData = $('Consolidar Datos').first().json;\n\nlet balanceText = '';\nlet estadoText = '';\nlet flujoText = '';\n\nextracts.forEach((item, idx) => {\n  const text = item.json.text || item.json.data || '';\n  if (idx === 0) balanceText = text;\n  if (idx === 1) estadoText = text;\n  if (idx === 2) flujoText = text;\n});\n\nreturn [{\n  json: {\n    ...consolidatedData,\n    textoBalance: balanceText,\n    textoEstadoResultados: estadoText,\n    textoFlujoCaja: flujoText,\n    documentosCombinados: `BALANCE GENERAL:\\n${balanceText}\\n\\n---\\n\\nESTADO DE RESULTADOS:\\n${estadoText}\\n\\n---\\n\\nFLUJO DE CAJA:\\n${flujoText}`\n  }\n}];"
      },
      "id": "combine-text-01",
      "name": "Combinar Textos",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3320, 380]
    },
    {
      "parameters": {
        "agent": "toolsAgent",
        "promptType": "define",
        "text": "=INFORMACIÓN DE LA EMPRESA:\n- Empresa: {{ $json.empresa }}\n- NIT: {{ $json.nit }}\n- Año de Fundación: {{ $json.anioFundacion }} ({{ $json.aniosFundacion }} años de operación)\n- Productos/Servicios: {{ $json.productosServicios }}\n- Principales Clientes: {{ $json.clientes }}\n- Principales Proveedores: {{ $json.proveedores }}\n- Canales de Distribución: {{ $json.distribucion }}\n\nDOCUMENTOS FINANCIEROS:\n{{ $json.documentosCombinados }}",
        "options": {
          "systemMessage": "Eres un analista financiero senior de una firma Big Four (Deloitte / KPMG / PwC / EY) especializado en evaluación crediticia empresarial para Colombia. Tu rol es analizar estados financieros, balances generales y flujos de caja con precisión técnica.\n\nTAREA: Analiza los documentos financieros proporcionados y genera una evaluación crediticia completa.\n\nANÁLISIS REQUERIDO:\n1. LIQUIDEZ: Razón corriente, prueba ácida, capital de trabajo\n2. SOLVENCIA: Razón de deuda, endeudamiento total, cobertura de intereses\n3. RENTABILIDAD: ROE, ROA, margen neto, margen operativo\n4. FLUJO DE CAJA: FCO, FCI, FCF, cobertura de servicio de deuda\n5. APALANCAMIENTO: Deuda/Patrimonio, Deuda/EBITDA\n6. ANÁLISIS DE NEGOCIO: Considera los años de operación, diversificación de clientes/proveedores, y canales de distribución\n\nSCORE CREDITICIO (0-1000):\n- 800-1000: Excelente — Riesgo Muy Bajo\n- 650-799: Bueno — Riesgo Bajo\n- 500-649: Regular — Riesgo Medio\n- 350-499: Deficiente — Riesgo Alto\n- 0-349: Crítico — Riesgo Muy Alto\n\nFORMATO DE RESPUESTA JSON:\n{\n  \"score\": <número 0-1000>,\n  \"nivelRiesgo\": \"<Muy Bajo|Bajo|Medio|Alto|Muy Alto>\",\n  \"categoria\": \"<Excelente|Bueno|Regular|Deficiente|Crítico>\",\n  \"resumenEjecutivo\": \"<párrafo de 3-4 oraciones>\",\n  \"analisisNegocio\": {\n    \"antiguedad\": \"<evaluación de años de operación>\",\n    \"diversificacionClientes\": \"<evaluación>\",\n    \"canalDistribucion\": \"<evaluación>\"\n  },\n  \"indicadores\": {\n    \"liquidez\": {\"razonCorriente\": <valor>, \"pruebaAcida\": <valor>, \"evaluacion\": \"<texto>\"},\n    \"solvencia\": {\"razonDeuda\": <valor>, \"evaluacion\": \"<texto>\"},\n    \"rentabilidad\": {\"roe\": <valor>, \"roa\": <valor>, \"evaluacion\": \"<texto>\"},\n    \"flujoCaja\": {\"cobertura\": <valor>, \"evaluacion\": \"<texto>\"}\n  },\n  \"fortalezas\": [\"<fortaleza 1>\", \"<fortaleza 2>\"],\n  \"riesgos\": [\"<riesgo 1>\", \"<riesgo 2>\"],\n  \"recomendacion\": \"<recomendación de crédito clara>\",\n  \"limiteCredito\": \"<rango sugerido en COP>\"\n}"
        }
      },
      "id": "ai-agent-01",
      "name": "Agente Financiero IA",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "typeVersion": 1.7,
      "position": [3600, 380]
    },
    {
      "parameters": {
        "model": "claude-opus-4-6",
        "options": {}
      },
      "id": "claude-model-01",
      "name": "Modelo Claude",
      "type": "@n8n/n8n-nodes-langchain.lmChatAnthropic",
      "typeVersion": 1.2,
      "position": [3600, 640],
      "credentials": {
        "anthropicApi": {
