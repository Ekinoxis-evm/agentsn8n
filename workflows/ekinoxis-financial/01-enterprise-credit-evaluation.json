      "parameters": {
        "jsCode": "const normalizedData = $('Normalizar Datos').first().json;\nconst folderData = $('Guardar ID Carpeta').first().json;\n\nconst uploads = $input.all();\nconst fileUrls = {};\nuploads.forEach(item => {\n  if (item.json.webViewLink) {\n    if (item.json.name?.includes('Certificado')) fileUrls.certificadoUrl = item.json.webViewLink;\n    if (item.json.name?.includes('Balance')) fileUrls.balanceUrl = item.json.webViewLink;\n    if (item.json.name?.includes('Estado')) fileUrls.estadoResultadosUrl = item.json.webViewLink;\n    if (item.json.name?.includes('Flujo')) fileUrls.flujoCajaUrl = item.json.webViewLink;\n    if (item.json.name?.includes('RUT')) fileUrls.rutUrl = item.json.webViewLink;\n  }\n});\n\nreturn [{\n  json: {\n    ...normalizedData,\n    folderId: folderData.folderId,\n    folderUrl: folderData.folderUrl,\n    ...fileUrls,\n    archivosCompletos: true\n  }\n}];"
      },
