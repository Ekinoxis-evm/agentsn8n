    {
      "parameters": {
        "jsCode": "const aiOutput = $input.first().json.output || $input.first().json.text || '';\nlet report;\ntry {\n  const jsonMatch = aiOutput.match(/\\{[\\s\\S]*\\}/);\n  report = jsonMatch ? JSON.parse(jsonMatch[0]) : { score: 0, nivelRiesgo: 'Error', categoria: 'Error', resumenEjecutivo: aiOutput };\n} catch(e) {\n  report = { score: 0, nivelRiesgo: 'Error en análisis', resumenEjecutivo: aiOutput };\n}\n\nconst businessData = $('Combinar Textos').first().json;\nreturn [{\n  json: {\n    solicitudId: businessData.solicitudId,\n    empresa: businessData.empresa,\n    nit: businessData.nit,\n    anioFundacion: businessData.anioFundacion,\n    aniosFundacion: businessData.aniosFundacion,\n    email: businessData.email,\n    telefono: businessData.telefono,\n    folderUrl: businessData.folderUrl,\n    fecha: businessData.fechaSolicitud,\n    score: report.score,\n    nivelRiesgo: report.nivelRiesgo,\n    categoria: report.categoria,\n    resumenEjecutivo: report.resumenEjecutivo,\n    analisisNegocio: report.analisisNegocio,\n    indicadores: report.indicadores,\n    fortalezas: report.fortalezas,\n    riesgos: report.riesgos,\n    recomendacion: report.recomendacion,\n    limiteCredito: report.limiteCredito,\n    reporteCompleto: report\n  }\n}];"
      },
