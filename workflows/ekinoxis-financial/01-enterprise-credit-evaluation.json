      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst solicitudId = 'CRED-' + Date.now();\nconst timestamp = new Date().toISOString();\nconst fechaSolicitud = new Date().toLocaleDateString('es-CO', {timeZone: 'America/Bogota'});\nconst anioActual = new Date().getFullYear();\nconst aniosFundacion = anioActual - parseInt(data['Año de Fundación'] || anioActual);\n\nconst folderName = `${solicitudId}_${data['Nombre de la Empresa'].replace(/[^a-zA-Z0-9áéíóúÁÉÍÓÚñÑ\\s]/g, '').substring(0, 50).trim()}`;\n\nreturn [{\n  json: {\n    solicitudId,\n    timestamp,\n    fechaSolicitud,\n    folderName,\n    empresa: data['Nombre de la Empresa']?.trim() || '',\n    nit: data['NIT']?.trim() || '',\n    anioFundacion: data['Año de Fundación'] || '',\n    aniosFundacion,\n    productosServicios: data['Productos y Servicios']?.trim() || '',\n    clientes: data['Principales Clientes']?.trim() || '',\n    proveedores: data['Principales Proveedores']?.trim() || '',\n    distribucion: data['Canales de Distribución']?.trim() || '',\n    email: data['Correo Electrónico de Contacto']?.trim().toLowerCase() || '',\n    telefono: data['Teléfono de Contacto']?.trim() || '',\n    estado: 'Nuevo - Documentos Recibidos'\n  }\n}];"
      },
